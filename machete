#!/usr/bin/env bash
# Thin wrapper around the Go binary. Builds on first run, then execs.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="${REPO_DIR}/dist/machete"
SRC_DIR="${REPO_DIR}/cmd/machete"

needs_build() {
  [[ ! -x "${BIN}" ]] && return 0
  local newest_src
  newest_src="$(find "${SRC_DIR}" "${REPO_DIR}/pkg" -name '*.go' -newer "${BIN}" -print -quit 2>/dev/null || true)"
  [[ -n "${newest_src}" ]]
}

if needs_build; then
  if ! command -v go >/dev/null 2>&1; then
    echo "machete: Go toolchain not found. Install Go or run 'make install' to build the binary." >&2
    exit 1
  fi
  mkdir -p "${REPO_DIR}/dist"
  go build -o "${BIN}" "${SRC_DIR}"
fi

exec "${BIN}" "$@"
