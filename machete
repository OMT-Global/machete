#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="${REPO_DIR}/scripts"

usage() {
  cat <<EOF
machete — swiss army knife for macOS setup and maintenance

Usage:
  ./machete <command>

Commands:
  setup      Bootstrap a new Mac: Xcode tools, Homebrew, packages, dotfiles, defaults
  snapshot   Export current state to repo: Brewfile, dotfiles, defaults template
  update     Upgrade all Homebrew packages and clean up
  doctor     Check what's installed, symlinked, and in sync with the repo
  sync       Pull latest repo changes and re-apply setup (idempotent)
  defaults   Apply macOS system preferences from defaults/macos-defaults.sh

Examples:
  ./machete setup        # new machine
  ./machete doctor       # check current state
  ./machete snapshot     # capture what's on your Mac now
  ./machete update       # keep packages current
  ./machete sync         # pull + re-apply after a change

EOF
}

CMD="${1:-}"

case "${CMD}" in
  setup)    exec "${SCRIPTS_DIR}/setup.sh" ;;
  snapshot) exec "${SCRIPTS_DIR}/snapshot.sh" ;;
  update)   exec "${SCRIPTS_DIR}/update.sh" ;;
  doctor)   exec "${SCRIPTS_DIR}/doctor.sh" ;;
  sync)     exec "${SCRIPTS_DIR}/sync.sh" ;;
  defaults)
    DEFAULTS_SCRIPT="${REPO_DIR}/defaults/macos-defaults.sh"
    if [[ -x "${DEFAULTS_SCRIPT}" ]]; then
      exec "${DEFAULTS_SCRIPT}"
    else
      echo "No defaults/macos-defaults.sh found. Run: ./machete snapshot"
      exit 1
    fi
    ;;
  help|--help|-h|"")
    usage
    ;;
  *)
    echo "Unknown command: ${CMD}"
    echo ""
    usage
    exit 1
    ;;
esac
